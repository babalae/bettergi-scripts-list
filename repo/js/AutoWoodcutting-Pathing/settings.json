    },
    {
        "name": "woodsMultiCheckbox",
        "type": "multi-checkbox",
        "label": "木材种类：不勾选默认全部支持木材",
        "options": [
            "桦木",
            "萃华木",
            "松木",
            "却砂木",
            "竹节",
            "垂香木",
            "杉木",
            "梦见木",
            "枫木",
            "孔雀木",
            "御伽木",
            "辉木",
            "业果木",
            "证悟木",
            "刺葵木",
            "柽木",
            "悬铃木",
            "椴木",
            "白梣木",
            "香柏木",
            "炬木",
            "白栗栎木",
            "灰灰楼林木",
            "燃爆木",
            "桃椰子木",
            "银冷杉木",
            "榛木",
            "夏栎木",
            "桤木"
