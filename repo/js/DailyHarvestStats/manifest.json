{
  "manifest_version": 1,
  "name": "每日收获统计",
  "version": "1.1",
  "bgi_version": "0.60.0",
  "description": "统计采集脚本期间的摩拉、狗粮经验与原石收获：在采集任务前后各放一次（采集前记起点、采集后结算），只算采集窗口内的收获、排除手动花费。跨天累计与日均、连续采集天数、周/月汇总与环比，支持多账号、抗中断；结果输出为方便小白阅读的网页报告（可切配色、明细表分页）与纯文本。",
  "tags": [
    "统计",
    "摩拉",
    "狗粮",
    "原石",
    "收获",
    "锄地"
  ],
  "authors": [
    {
      "name": "Zongyeeeee",
      "links": "https://github.com/Zongyeeeee"
    }
  ],
  "settings_ui": "settings.json",
  "main": "main.js",
  "saved_files": [
    "local/harvest_stats.json",
    "local/harvest_stats.bak.json",
    "local/harvest_report.txt",
    "local/harvest_report.html"
  ]
}
